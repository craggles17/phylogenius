<nav class="rulebook__nav">
  <ul class="nav__list">
    {{#each sections}}
    <li class="nav__item {{#if (eq this.id ../currentSection)}}nav__item--active{{/if}}">
      <a href="{{this.href}}" class="nav__link">
        {{this.title}}
      </a>
      {{#if this.subsections}}
      <ul class="nav__sublist">
        {{#each this.subsections}}
        <li class="nav__subitem">
          <a href="{{this.href}}" class="nav__sublink">{{this.title}}</a>
        </li>
        {{/each}}
      </ul>
      {{/if}}
    </li>
    {{/each}}
  </ul>
</nav>

